--Q8. What is the most expensive book? Show its title and price.
select title, price from books order by price desc limit 1 -- sort the records descending and take the first row

select * 
from books 
order by price desc 
limit 1

-- we can find what is the maximum price and then filer the table to get books where price = max(price)
select max(price) from books  -- this finds the the max of the price

select * from books where price = 19.99 

select * from books where price = (select max(price) from books)


