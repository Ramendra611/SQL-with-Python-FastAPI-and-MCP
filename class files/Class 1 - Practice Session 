-- Q1. Show all books in the table — every column, every row.
select * from books

select * from books limit 3

-- Q2. Show only the title and author of every book.
select title, author from books


-- Q3. How many genres are there?
select genre from  books -- this generates the column genre

select  distinct genre from books  -- this is the list of unique genres

select  count(distinct genre) from books -- this gives the count of the genres

-- Q4. Show all books that belong to the 'Fiction' genre.

select * from books where genre = 'Fiction' --this generate the list of books

select count(*) from books where genre = 'Fiction' --this will give the count of the rows based on the filter

-- Q5. Show all books that are currently in stock (in_stock = TRUE), sorted by price from lowest to highest.
select * 
from books 
where in_stock = true
order by price asc -- this will sort the records ascending based on price

select * 
from books 
where in_stock = true
order by price desc -- this will sort the records ascending based on price

-- Q6. Show all books where the price is less than 15.00. Display only title, author, and price.
select title, author, price 
from books
where price < 15
order by price desc

-- get count of book with above filter
select count(*) 
from books
where price < 15

--Q7. How many books are in the table in total?
