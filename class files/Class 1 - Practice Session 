CREATE TABLE books (
    book_id     SERIAL        PRIMARY KEY,
    title       VARCHAR(200)  NOT NULL,
    author      VARCHAR(100)  NOT NULL,
    genre       VARCHAR(50),
    price       NUMERIC(6,2)  CHECK (price >= 0),
    pages       INT           CHECK (pages > 0),
    published   INT,          -- year e.g. 2020
    in_stock    BOOLEAN       DEFAULT TRUE
)


