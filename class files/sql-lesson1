-- add a city column
ALTER TABLE users
ADD COLUMN city VARCHAR(100);

select * from users

-- add city values for a filter
UPDATE users
SET city = 'Delhi'
WHERE name = 'ram';

select * from users

--- adding for others as well
UPDATE users
SET city = CASE
    WHEN name = 'ram' THEN 'Delhi'
    WHEN name = 'shyam' THEN 'Mumbai'
    WHEN name = 'mohan' THEN 'Bangalore'
    WHEN name = 'sita' THEN 'Chennai'
    WHEN name = 'gita' THEN 'Kolkata'
    WHEN name = 'ravi' THEN 'Hyderabad'
    WHEN name = 'amit' THEN 'Pune'
    WHEN name = 'neha' THEN 'Ahmedabad'
    WHEN name = 'rohit' THEN 'Jaipur'
    WHEN name = 'priya' THEN 'Lucknow'
