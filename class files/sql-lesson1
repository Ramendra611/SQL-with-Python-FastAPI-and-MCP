UPDATE users u
SET city = v.city
FROM (
    VALUES
    ('ram','New Delhi'),
    ('shyam','Navi Mumbai'),
    ('mohan','Urban Bangalore'),
    ('sita','Madurai'),
    ('gita','Kolkata')
) AS v(name, city)
WHERE u.name = v.name;


