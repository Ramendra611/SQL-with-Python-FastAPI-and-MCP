-- Window Function
	function_name() OVER ( partition by col1, col1 order by col3 )

-- - ROW_NUMBER
-- - RANK --> if there is a tie then rows will be skipped (1, 1, 3)
-- - DENSE_RANK -> the rank is not skipped there is no gap(1, 1, 2, 2, 2, 3)


-- Q1. Rank all employees by salary and show the difference between ROW_NUMBER, RANK, and DENSE_RANK

select name, 
		department, 
		salary, 
		row_number () over(order by salary desc ) as row_num,
		rank() over (order by salary desc ) as rnk, 
		dense_rank() over (order by salary desc ) as dense_rnk
		
from employees 
order by salary desc


-- Q2. Rank employees by salary within their department
select *, 
		dense_rank() over (partition by department order by salary desc) as rn

from employees


-- find the highest earning people in each department

with ranked as (select *, 
		dense_rank() over (partition by department order by salary desc) as rn

from employees)

select * from ranked where rn = 1 -- selecting only the top salary in each department


-- Show each employee's salary alongside their department's average, and the difference
select * , 
		round(avg(salary) over (partition by department)) as deptt_average_salary
from employees


-- Which are the department whose average salary is less than 80000
select department, avg(salary)
from employees 
group by department

