CREATE TABLE employees (
    id          SERIAL PRIMARY KEY,
    name        VARCHAR(100),
    department  VARCHAR(50),
    role        VARCHAR(50),
    salary      INT,
    hire_date   DATE,
    manager_id  INT
);

CREATE TABLE monthly_sales (
    id           SERIAL PRIMARY KEY,
    employee_id  INT REFERENCES employees(id),
    sale_month   DATE,    -- first of each month
    amount       NUMERIC(12,2)
);

CREATE TABLE orders (
    order_id     SERIAL PRIMARY KEY,
    customer_id  INT,
    order_date   DATE,
    amount       NUMERIC(10,2)
);




