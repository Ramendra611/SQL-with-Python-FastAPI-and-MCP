-- delete and recreate the tables if they are present
DROP TABLE IF EXISTS watch_history;
DROP TABLE IF EXISTS subscriptions;
DROP TABLE IF EXISTS show_genres;
DROP TABLE IF EXISTS shows;
DROP TABLE IF EXISTS genres;
DROP TABLE IF EXISTS users;

CREATE TABLE users (
    id              SERIAL          PRIMARY KEY,
    name            VARCHAR(100)    NOT NULL,
    email           VARCHAR(150)    NOT NULL UNIQUE,
    city            VARCHAR(50)     NOT NULL,
    state           VARCHAR(50)     NOT NULL,
    joined_on       DATE            NOT NULL DEFAULT CURRENT_DATE,
    plan            VARCHAR(20)     NOT NULL DEFAULT 'Free'
                                    CHECK (plan IN ('Free', 'Mobile', 'Super', 'Premium'))
);

CREATE TABLE genres (
    id      SERIAL          PRIMARY KEY,
    name    VARCHAR(50)     NOT NULL UNIQUE
);

CREATE TABLE shows (
    id              SERIAL          PRIMARY KEY,
    title           VARCHAR(150)    NOT NULL,
    language        VARCHAR(30)     NOT NULL,
    release_year    INT             NOT NULL CHECK (release_year >= 2000),
    rating          NUMERIC(3,1)    CHECK (rating BETWEEN 1.0 AND 10.0),
    is_premium      BOOLEAN         NOT NULL DEFAULT FALSE,
    total_episodes  INT             NOT NULL DEFAULT 1 CHECK (total_episodes >= 1)
);

-- Many-to-many: one show can have many genres, one genre spans many shows
CREATE TABLE show_genres (
    show_id     INT     NOT NULL REFERENCES shows(id)  ON DELETE CASCADE,
    genre_id    INT     NOT NULL REFERENCES genres(id) ON DELETE CASCADE,
    PRIMARY KEY (show_id, genre_id)   -- composite PK, no separate id needed
);

CREATE TABLE subscriptions (
    id              SERIAL      PRIMARY KEY,
    user_id         INT         NOT NULL REFERENCES users(id),
    plan            VARCHAR(20) NOT NULL
                                CHECK (plan IN ('Mobile', 'Super', 'Premium')),
    started_on      DATE        NOT NULL,
    expires_on      DATE        NOT NULL,
    CHECK (expires_on > started_on)   -- table-level constraint
);

CREATE TABLE watch_history (
    id              SERIAL      PRIMARY KEY,
    user_id         INT         NOT NULL REFERENCES users(id),
    show_id         INT         NOT NULL REFERENCES shows(id),
    watched_on      DATE        NOT NULL DEFAULT CURRENT_DATE,
    minutes_watched INT         NOT NULL CHECK (minutes_watched > 0),
    completed       BOOLEAN     NOT NULL DEFAULT FALSE
);



