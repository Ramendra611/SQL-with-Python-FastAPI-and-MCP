--  Users who watched every show rated above 9.0:
 --> we need to find out how many 9+ shows a user has seen that should be equal to total 9+ shows


 --> how many 9+ rated shows
 -- select  count(*) from shows group by rating having rating > 9.0
 select count(*) from shows where rating > 9.0

 --> Which shows are 9+ rated
 select id from shows where rating > 9.0


 --> how many 9+ shows a user has seen

 select user_id, count(distinct show_id) 
 from watch_history
 where show_id in (select id from shows where rating > 9.0)
 group by user_id
 having  count(distinct show_id) =  ( select count(*) from shows where rating > 9.0)
 
 --> first find how many total 9+ movies are there (result 1)
 --> filter the watch_history for 9+ rated shows
 --> groupby user_id and find out how many 9+ shows a user has watched (result 2)
 --> filter rows where result2 is equal to result 1

select name 
from users 
where id in 
( select user_id, count(distinct show_id) 
 from watch_history
 where show_id in (select id from shows where rating > 9.0)
 group by user_id
 having  count(distinct show_id) =  ( select count(*) from shows where rating > 9.0))

