-- Question:  Shows that have at least one watch history entry
	-- (i.e. shows that have actually been watched)
	--> which are the shows that are in the watch history

select title 
from shows 
where id in 
(select distinct show_id from watch_history) 
order by title


-- Solve the same question using join
select distinct(title)
from watch_history w
join shows s
on s.id = w.show_id
order by title


-- Question: Find all users who have never watched any show rated above 9.0. Show name, city, and plan.

