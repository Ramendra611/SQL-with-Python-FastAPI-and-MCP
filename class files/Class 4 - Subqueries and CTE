with ranked as (select * , 
						row_number () over ( partition by user_id order by watched_on desc ) as rn
				from  watch_history)

select user_id, users.name, title, watched_on from ranked 
left join shows  on ranked.show_id = shows.id
join users on users.id = ranked.user_id
where rn = 1

