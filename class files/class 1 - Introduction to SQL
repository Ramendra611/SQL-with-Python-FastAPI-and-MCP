    ('USB-C Cable',       'Accessories',   9.99, 200 );

INSERT INTO products (name, category, price, stock, is_available)
VALUES ('Apple MacBook Air', 'Laptops', 599.99, 25, false);


SELECT * FROM products

------ Explore more on the SELECT Query ------

-- Get all the rows and all the columns
SELECT  * FROM products

-- Use LIMIT command
SELECT  * 
FROM products
LIMIT 5

-- We can select specific columns
SELECT name, price
FROM products
LIMIT 3

-- show the categories
select category from products

-- show the unique categories
select distinct category from products

-- Show the name and stock of the products from electronics ( filtering)

SELECT name, stock 
FROM products
WHERE category = 'Electronics'

-- Show the name and stock of the products from electronics or clothing ( filtering)
SELECT name, stock, category , price
FROM products
WHERE category IN ('Electronics', 'Clothing')

-- Show the details of the products from electronics or clothing where price is more than 700 ( filtering)
SELECT name, stock, category , price
FROM products
WHERE category IN ('Electronics', 'Clothing')
AND price >700


-- UPDATE some records
select * from products

-- Update the price of Apple Macbook Pro from 1999.99 to 1599.99
UPDATE products
SET PRICE = 1599
where name = 'Apple MacBook Pro'

UPDATE products
SET PRICE = 25.99
where product_id = 4

select * from products

UPDATE products
SET price =89.99, stock =145
where name like '%Nike%' -- didnt need write the entire string.(Matching using wildcards)

select * from products

-- DELETE command to remove data from a table
DELETE FROM products
where product_id = 3

select * from products

-- DELETE ( we can delete the records based on some condition)
-- delete all products which are not available
delete from products
where is_available = false 

select * from products


-- ALTER - change the structure of an existing table 

-- change a columns data type
ALTER TABLE products
ALTER COLUMN stock TYPE BIGINT

-- add some constraint like stock >=0
ALTER TABLE products
ADD CONSTRAINT stock_constraint check(stock >=0)

