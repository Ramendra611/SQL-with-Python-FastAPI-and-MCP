------------- Filtering the data -------------
-- Question: who are the students from New Delhi?

-- Filter the data using WHERE ( common pattern SELECT -> FROM -> WHERE)
SELECT * 
FROM students
WHERE city = 'New Delhi'

SELECT * 
FROM students
WHERE city = 'Hyderabad'



-- Create a table with some constraints

-- Unique ( can have NULL values)
-- NOT NULL
-- PRIMARY KEY ( UNIQUE + NOT NULL)

-- Common DataTypes(
INT, 
SERIAL, 
FLOAT, 
NUMERIC(p,s), 
VARCHAR(N), 
TEXT, 
BOOLEAN, 
DATE, 
TIMESTAMP, 
TIME, 
)


-- DROP A TABLE
DROP TABLE products

CREATE  TABLE products (
product_id  SERIAL  PRIMARY KEY,-- the value has to be unique and not null
name VARCHAR(100) NOT NULL,  -- the value cant be null
category VARCHAR(100) , 
price FLOAT CHECK(price >=0), --using a check constraint
stock INT  DEFAULT 0 , -- by default the value will be 0
is_available BOOLEAN DEFAULT TRUE -- this can be only True or False
)

-- see the content of the table
SELECT * FROM products

-- Insert some data into the products table
INSERT INTO products (name, category, price, stock)
VALUES ('Apple MacBook Pro', 'Laptops', 1999.99, 15);

INSERT INTO products (name, category, price, stock)
VALUES
    ('Samsung TV 55"',    'Electronics', 799.99,  30),
