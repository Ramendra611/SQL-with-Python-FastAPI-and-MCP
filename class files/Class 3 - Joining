-- What is the Revenue per customer
with order_item_revenue as (select c.id as customer_id,  -- this is at order_items_level
		c.name, 
		orders.id as order_id,
		orders.status as order_status, 
		order_items.quantity, 
		order_items.unit_price , 
		order_items.quantity * order_items.unit_price as total_revenue
from customers c
join orders on c.id = orders.customer_id
join order_items on order_items.order_id = orders.id
where orders.status not in ('Cancelled')) -- we dont want to include the cancelled orders

select name, sum(total_revenue) as revenue
from order_item_revenue
group by name
order by revenue desc


