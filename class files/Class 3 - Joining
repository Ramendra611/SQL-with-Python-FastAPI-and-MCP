select * from orders order by customer_id

-- Who are the customers (id) who have placed an order?
select distinct(customer_id) from orders order by customer_id

-- Who are the customer (id) who have not placed an order?
select distinct(id) from customers 
where id not in (select distinct(customer_id) from orders order by customer_id)
order by id

-- Get the names of the customers who have placed an order
---- strategy : inner join the customers and orders table and get distinct names

select distinct (name) from customers
inner join orders
on customers.id = orders.customer_id
order by customers.name


-- Get the names of customers who have not placed order?
--- Strategy : left Join the customers and orders table and filter out the null from orders

select name from customers cust
left join orders o
on cust.id = o.customer_id
where o.id is Null 
order by cust.id




-- Which customer has placed how many orders? Show name of the name and the count

select c.name, count(*) from customers c
join orders o
on c.id = o.customer_id
group by name
order by c.name


